# ── Content Generator ──────────────────────────────────────────
# Generator runs in CI via GitHub Actions (generate-content.yml),
# or locally for preview/testing.

# Output directory for generated HTML pages.
# Default: parent of generator/ (../is-pro.dev, i.e. the repo root)
# SITE_ROOT=../is-pro.dev

# Path to the dash SQLite database (domains.db) for registered subdomains.
# Default: ../dash/data/domains.db
# DB_PATH=../dash/data/domains.db

# ── Ollama (AI content generation) ──────────────────────────────
# The generator can optionally use a local Ollama instance to
# produce AI-written blog posts and guides.  When set to 1, AI
# generation is skipped and fallback content is used instead.
# In CI this is always 1 (no Ollama runner available).
# OLLAMA_OFFLINE=1

# Ollama server URL (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# Ollama model name (default: llama3.2:latest)
# OLLAMA_MODEL=llama3.2:latest

# ── CI Only ────────────────────────────────────────────────────
# GitHub Personal Access Token used by GitHub Actions to check out
# repos and push generated content.  Set as a repository secret,
# never committed.
# GH_PAT=ghp_...
